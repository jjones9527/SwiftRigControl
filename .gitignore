# macOS
.DS_Store

# Swift Package Manager — unanchored so nested SwiftPM projects
# (Tools/SwiftRigControlTools, Documentation/StandaloneDiscoveryValidator,
# any future examples) don't leak build artifacts.
.build/
Packages/
Package.resolved
.swiftpm/configuration/registries.json
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata

# Local DocC build output (CI also writes here; outside CI it's churn)
docs-build/

# Xcode
xcuserdata/
DerivedData/
*.xcworkspace
!Package.swift.xcworkspace

# Credentials
.netrc

# PDFs (copyrighted manufacturer manuals - users should download from source)
*.pdf

# Test scripts
*.sh

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# Development notes (if keeping locally)
# Documentation/Development/
